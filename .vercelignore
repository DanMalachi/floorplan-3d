# Dev-only data / corpora not needed to build or run the app in production.
# (data/ is intentionally NOT ignored — data/tambour-colors.json is imported at build.)
floorplan-gt/
floorplan_for_training/
eval/
eval-out/
out/
docs/
scripts/
*.tsbuildinfo

# Real IKEA .glb models (~400 MB) are served from Vercel Blob, not bundled — the
# catalog references them by URL (data/furniture-ikea.blob.json). Keep them out of
# the deployment upload. Transparent thumbnails under .../thumb/ ARE shipped.
public/furniture/ikea/*.glb

# Regenerable IKEA raw API cache — never needed at build/runtime.
data/raw/
