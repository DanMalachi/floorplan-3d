# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# phase 2.5 eval harness outputs
/eval-out/

# python bytecode (scrapers / eval scripts)
__pycache__/
*.pyc

# CAD import fixtures — large .dwg binaries + generated .dxf conversions; keep
# these local only, out of git history
floorplan_for_training/dxf_dwg/

# IKEA pipeline raw cache — regenerable intermediate (raw API responses + HTTP
# cache). Committed static asset: the catalog JSON data/furniture-ikea*.json
# (incl. the .blob.json URL manifest).
/data/raw/

# Real IKEA .glb models (~400 MB) are hosted on Vercel Blob, not committed — the
# catalog references them by URL via data/furniture-ikea.blob.json. Regenerate
# locally with `npm run ikea:models`; upload with `npm run ikea:upload`.
/public/furniture/ikea/*.glb

# Thumbnails are regenerable (`npm run ikea:thumbnails`) and kept out of git to
# avoid hundreds of binaries in history; they're still shipped to prod because the
# CLI deploy uploads them from local disk (see .vercelignore, which keeps them in).
/public/furniture/ikea/thumb/

.vercel
