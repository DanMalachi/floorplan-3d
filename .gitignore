# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# phase 2.5 eval harness outputs
/eval-out/

# python bytecode (scrapers / eval scripts)
__pycache__/
*.pyc

# CAD import fixtures — large .dwg binaries + generated .dxf conversions; keep
# these local only, out of git history
floorplan_for_training/dxf_dwg/

.vercel
